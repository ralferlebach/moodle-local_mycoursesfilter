{{!
    @template local_mycoursesfilter/course_summary_list

    Compact summary view of filtered courses.
}}
<div class="local-mycoursesfilter-summary list-group">
    {{#courses}}
        <div class="list-group-item local-mycoursesfilter-course-summary-item">
            <div class="d-flex align-items-start gap-3">
                <div class="local-mycoursesfilter-media">
                    <a href="{{viewurl}}" class="d-block">
                        <img class="courseimage rounded" src="{{courseimage}}" alt="{{fullname}}">
                    </a>
                </div>
                <div class="flex-grow-1 min-width-0">
                    <div class="d-flex align-items-start justify-content-between gap-2">
                        <div class="min-width-0">
                            <h3 class="h6 mb-1"><a href="{{viewurl}}">{{{fullname}}}</a></h3>
                            {{#showcoursecategory}}
                                <div class="text-muted small mb-2 text-truncate">{{coursecategory}}</div>
                            {{/showcoursecategory}}
                        </div>
                        {{#isfavourite}}
                            <span class="badge bg-warning text-dark local-mycoursesfilter-badge">{{favouritelabel}}</span>
                        {{/isfavourite}}
                    </div>
                    {{#hassummary}}
                        <div class="local-mycoursesfilter-summarytext local-mycoursesfilter-summarytext--expanded">{{{summaryhtml}}}</div>
                    {{/hassummary}}
                </div>
            </div>
        </div>
    {{/courses}}
</div>
