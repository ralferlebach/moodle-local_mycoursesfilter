{{!
    @template local_mycoursesfilter/course_summary_list

    Compact summary view aligned with Moodle's my/courses feel.

    Example context (json):
    {
        "courses": [
            {
                "viewurl": "/course/view.php?id=2",
                "courseimage": "https://example.invalid/course.jpg",
                "fullname": "Biology 101",
                "showcoursecategory": true,
                "coursecategory": "Science",
                "isfavourite": false,
                "summaryhtml": "<p>Course summary</p>",
                "hassummary": true
            }
        ]
    }

    @copyright  2026 Ralf Erlebach <moodle-dev@ralferlebach.de>
    @license    http://www.gnu.org/copyleft/gpl.html GNU GPL v3 or later
}}
<div class="local-mycoursesfilter-summary list-group list-group-flush">
    {{#courses}}
        <div class="list-group-item local-mycoursesfilter-summaryitem px-0 py-2 border-left-0 border-right-0 border-start-0 border-end-0 rounded-0">
            <div class="d-flex align-items-start local-mycoursesfilter-summaryrow">
                <div class="local-mycoursesfilter-thumbwrap me-3 mr-3 mb-2 mb-md-0">
                    <a href="{{viewurl}}" class="d-block">
                        <img class="local-mycoursesfilter-thumb rounded" src="{{courseimage}}" alt="{{fullname}}">
                    </a>
                </div>

                <div class="flex-grow-1 local-mycoursesfilter-flexcontent">
                    <div class="d-flex align-items-start justify-content-between local-mycoursesfilter-coursehead mb-1">
                        <div class="local-mycoursesfilter-flexcontent">
                            <h4 class="h6 mb-1 local-mycoursesfilter-coursetitle"><a href="{{viewurl}}">{{{fullname}}}</a></h4>
                            {{#showcoursecategory}}
                                <div class="text-muted small local-mycoursesfilter-meta mb-1">{{coursecategory}}</div>
                            {{/showcoursecategory}}
                        </div>
                        {{#isfavourite}}
                            <span class="badge badge-warning bg-warning text-dark text-nowrap">{{favouritelabel}}</span>
                        {{/isfavourite}}
                    </div>

                    {{#hassummary}}
                        <div class="small text-muted local-mycoursesfilter-summarytext">{{{summaryhtml}}}</div>
                    {{/hassummary}}
                </div>
            </div>
        </div>
    {{/courses}}
</div>
