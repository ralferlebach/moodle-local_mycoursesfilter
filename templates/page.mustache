{{!
    @template local_mycoursesfilter/page

    Wrapper template for the filtered course cards page.

    Context variables required for this template:
    * showbackbutton - Whether to render the back button.
    * backurl - The local return URL.
    * backlabel - The label for the back button.
    * heading - The result heading.
    * hascourses - Whether the result list is not empty.
    * nocoursefound - Empty-state message.
    * cardshtml - Pre-rendered core course cards markup.
}}
<div class="local-mycoursesfilter">
    {{#showbackbutton}}
        <div class="mb-3">
            <a class="btn btn-secondary" href="{{backurl}}">{{backlabel}}</a>
        </div>
    {{/showbackbutton}}

    <h2>{{heading}}</h2>

    {{#hascourses}}
        {{{cardshtml}}}
    {{/hascourses}}

    {{^hascourses}}
        <div class="alert alert-info" role="status">{{nocoursefound}}</div>
    {{/hascourses}}
</div>
