{{!
    @template local_mycoursesfilter/page

    Core-aligned wrapper for the filtered course overview page.

    Example context (json):
    {
        "showbackbutton": true,
        "backurl": "/course/view.php?id=2",
        "backlabel": "Back",
        "sectiontitle": "Course overview",
        "toolbararialabel": "Course overview controls",
        "groupingbuttonlabel": "All",
        "groupingarialabel": "Dropdown menu for the grouping",
        "groupingitems": [
            {"label": "All", "url": "/local/mycoursesfilter/index.php?filter=all", "active": true}
        ],
        "searchformurl": "/local/mycoursesfilter/index.php",
        "searchhiddeninputs": [
            {"name": "filter", "value": "all"}
        ],
        "searchinputlabel": "Search by course name",
        "searchplaceholder": "Search",
        "searchquery": "Biology",
        "sortingbuttonlabel": "Sorted by last accessed",
        "sortingarialabel": "Dropdown menu for the sorting",
        "sortingitems": [
            {
                "label": "Sorted by last accessed",
                "url": "/local/mycoursesfilter/index.php?sort=lastaccess",
                "active": true
            }
        ],
        "displaybuttonlabel": "Card",
        "displayarialabel": "Dropdown menu for the display",
        "displayitems": [
            {"label": "Card", "url": "/local/mycoursesfilter/index.php?view=card", "active": true}
        ],
        "currentview": "card",
        "currentfilter": "all",
        "currentsort": "lastaccess",
        "hascourses": true,
        "courseshtml": "<div>Rendered courses</div>",
        "nocoursefound": "No courses found."
    }
}}
<div class="local-mycoursesfilter-page">
    <section class="local-mycoursesfilter block_myoverview block card mb-3" aria-labelledby="local-mycoursesfilter-blocktitle">
        <div class="card-body p-3">
            <div class="d-flex align-items-center flex-wrap">
                <h3 id="local-mycoursesfilter-blocktitle" class="h5 card-title d-inline mb-0">{{sectiontitle}}</h3>
                {{#showbackbutton}}
                    <div class="ms-auto ml-auto">
                        <a class="btn btn-outline-primary" href="{{backurl}}">{{backlabel}}</a>
                    </div>
                {{/showbackbutton}}
            </div>

            <div class="card-text content mt-3">
                <div class="block-myoverview block-cards local-mycoursesfilter-overview" data-region="myoverview">
                    <div role="search" data-region="filter" class="d-flex align-items-center my-2 local-mycoursesfilter-toolbar" aria-label="{{toolbararialabel}}">
                        <div class="row g-0 w-100 local-mycoursesfilter-toolbar-row">
                            <div class="dropdown mb-1 me-1 mr-1 local-mycoursesfilter-toolbar-item local-mycoursesfilter-toolbar-item--grouping">
                                <button id="groupingdropdown" type="button" class="btn btn-outline-secondary dropdown-toggle text-nowrap" data-bs-toggle="dropdown" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false" aria-label="{{groupingarialabel}}">
                                    <span data-active-item-text>{{groupingbuttonlabel}}</span>
                                </button>
                                <ul class="dropdown-menu" role="menu" data-show-active-item data-skip-active-class="true" aria-labelledby="groupingdropdown">
                                    {{#groupingitems}}
                                        <li>
                                            <a class="dropdown-item {{#active}}active{{/active}}" href="{{url}}" role="menuitem" {{#active}}aria-current="true"{{/active}}>{{label}}</a>
                                        </li>
                                    {{/groupingitems}}
                                </ul>
                            </div>

                            <div class="mb-1 me-1 mr-1 flex-grow-1 local-mycoursesfilter-toolbar-item local-mycoursesfilter-toolbar-item--search">
                                <form method="get" action="{{searchformurl}}" class="d-flex flex-wrap align-items-center simplesearchform">
                                    {{#searchhiddeninputs}}
                                        <input type="hidden" name="{{name}}" value="{{value}}">
                                    {{/searchhiddeninputs}}
                                    <div class="input-group searchbar w-100" role="search">
                                        <label for="local-mycoursesfilter-searchinput">
                                            <span class="sr-only">{{searchinputlabel}}</span>
                                        </label>
                                        <input type="text" id="local-mycoursesfilter-searchinput" data-region="input" data-action="search" class="form-control withclear rounded" placeholder="{{searchplaceholder}}" name="q" value="{{searchquery}}" autocomplete="off">
                                    </div>
                                </form>
                            </div>

                            <div class="mb-1 me-1 mr-1 d-flex flex-wrap align-items-center local-mycoursesfilter-toolbar-item local-mycoursesfilter-toolbar-item--sort">
                                <div class="dropdown">
                                    <button id="sortingdropdown" type="button" class="btn btn-outline-secondary dropdown-toggle text-nowrap" data-bs-toggle="dropdown" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false" aria-label="{{sortingarialabel}}">
                                        <span data-active-item-text>{{sortingbuttonlabel}}</span>
                                    </button>
                                    <ul class="dropdown-menu" role="menu" data-show-active-item data-skip-active-class="true" aria-labelledby="sortingdropdown">
                                        {{#sortingitems}}
                                            <li>
                                                <a class="dropdown-item {{#active}}active{{/active}}" href="{{url}}" role="menuitem" {{#active}}aria-current="true"{{/active}}>{{label}}</a>
                                            </li>
                                        {{/sortingitems}}
                                    </ul>
                                </div>
                            </div>

                            <div class="dropdown mb-1 local-mycoursesfilter-toolbar-item local-mycoursesfilter-toolbar-item--display">
                                <button id="displaydropdown" type="button" class="btn btn-outline-secondary dropdown-toggle text-nowrap" data-bs-toggle="dropdown" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false" aria-label="{{displayarialabel}}">
                                    <span data-active-item-text>{{displaybuttonlabel}}</span>
                                </button>
                                <ul class="dropdown-menu" role="menu" data-show-active-item data-skip-active-class="true" aria-labelledby="displaydropdown">
                                    {{#displayitems}}
                                        <li>
                                            <a class="dropdown-item {{#active}}active{{/active}}" href="{{url}}" role="menuitem" {{#active}}aria-current="true"{{/active}}>{{label}}</a>
                                        </li>
                                    {{/displayitems}}
                                </ul>
                            </div>
                        </div>
                    </div>

                    <div class="container-fluid p-0">
                        <div id="local-mycoursesfilter-courses-view" class="local-mycoursesfilter-courses-view" data-region="courses-view" data-display="{{currentview}}" data-grouping="{{currentfilter}}" data-sort="{{currentsort}}">
                            <div data-region="course-view-content">
                                {{#hascourses}}
                                    {{{courseshtml}}}
                                {{/hascourses}}

                                {{^hascourses}}
                                    <div class="alert alert-info mb-0" role="status">{{nocoursefound}}</div>
                                {{/hascourses}}
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
</div>
