{{!
    @template local_mycoursesfilter/page

    Wrapper template for the filtered course overview page.
}}
<div class="local-mycoursesfilter">
    <div class="d-flex flex-wrap justify-content-between align-items-center mb-3">
        <div>
            <h2 class="h3 mb-0">{{sectiontitle}}</h2>
            <p class="text-muted mb-0">{{resultsheading}}</p>
        </div>
        {{#showbackbutton}}
            <div class="mt-2 mt-sm-0">
                <a class="btn btn-outline-primary" href="{{backurl}}">{{backlabel}}</a>
            </div>
        {{/showbackbutton}}
    </div>

    <div class="local-mycoursesfilter-toolbar card mb-4">
        <div class="card-body">
            <div class="mb-3">
                <div class="small text-muted mb-2">{{filterlabel}}</div>
                <ul class="nav nav-pills local-mycoursesfilter-pills">
                    {{#filterlinks}}
                        <li class="nav-item mr-2 mb-2">
                            <a class="nav-link {{#active}}active{{/active}}" href="{{url}}">{{label}}</a>
                        </li>
                    {{/filterlinks}}
                </ul>
            </div>

            <form method="get" action="{{formurl}}">
                {{#hiddeninputs}}
                    <input type="hidden" name="{{name}}" value="{{value}}">
                {{/hiddeninputs}}
                <div class="form-row align-items-end">
                    <div class="form-group col-12 col-lg-5">
                        <label for="local-mycoursesfilter-q">{{searchlabel}}</label>
                        <input id="local-mycoursesfilter-q" class="form-control" type="text" name="q" value="{{searchquery}}">
                    </div>
                    <div class="form-group col-12 col-md-6 col-lg-3">
                        <label for="local-mycoursesfilter-sort">{{sortlabel}}</label>
                        <select id="local-mycoursesfilter-sort" class="custom-select" name="sort">
                            {{#sortoptions}}
                                <option value="{{value}}" {{#selected}}selected{{/selected}}>{{label}}</option>
                            {{/sortoptions}}
                        </select>
                    </div>
                    <div class="form-group col-12 col-md-6 col-lg-2">
                        <label for="local-mycoursesfilter-view">{{viewlabel}}</label>
                        <select id="local-mycoursesfilter-view" class="custom-select" name="view">
                            {{#viewoptions}}
                                <option value="{{value}}" {{#selected}}selected{{/selected}}>{{label}}</option>
                            {{/viewoptions}}
                        </select>
                    </div>
                    <div class="form-group col-12 col-lg-2 d-flex">
                        <input type="hidden" name="filter" value="{{currentfilter}}">
                        <button type="submit" class="btn btn-primary mr-2 flex-fill">{{submitlabel}}</button>
                        <a class="btn btn-secondary" href="{{reseturl}}">{{resetlabel}}</a>
                    </div>
                </div>
            </form>
        </div>
    </div>

    {{#hascourses}}
        {{{courseshtml}}}
    {{/hascourses}}

    {{^hascourses}}
        <div class="alert alert-info" role="status">{{nocoursefound}}</div>
    {{/hascourses}}
</div>
